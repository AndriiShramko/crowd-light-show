{
  "name": "crowd-light-show",
  "version": "0.13.0",
  "description": "Turn a crowd's phones into one synchronized light show, in time with the music. Open-source web app — scan a QR, the whole audience flashes together. Concerts, clubs, stadiums, parties.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Andrii Shramko <zmei116@gmail.com> (https://www.linkedin.com/in/andrii-shramko/)",
