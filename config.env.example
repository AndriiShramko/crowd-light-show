# Copy to config.env (which is gitignored) for the production docker-compose.yml.
# NEVER commit the real config.env or real secrets.

# Operator console password. For production use a scrypt hash (salt:hash), NOT a plaintext:
#   OPERATOR_PASS_HASH=<salt>:<hash>
# For local dev a plaintext is fine and is hashed on boot:
OPERATOR_PASS=change-me

# Secret used to sign the console/operator session tokens (any long random string).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
